{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@the-oracle/content": ["packages/content/src/index.ts"],
      "@the-oracle/core": ["packages/core/src/index.ts"],
      "@the-oracle/persistence": ["packages/persistence/src/index.ts"],
      "@the-oracle/testkit": ["packages/testkit/src/index.ts"],
      "@the-oracle/ui": ["packages/ui/src/index.ts"]
    }
  }
}
