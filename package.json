{
  "name": "the-oracle",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --filter @the-oracle/web dev",
    "art:meshy": "node scripts/art/meshy.mjs",
    "art:pixel": "node scripts/art/pixel-art.mjs",
    "art:pixel-buildings": "node scripts/art/export-building-pixel-assets.mjs",
    "art:pixel-flora": "node scripts/art/export-flora-runtime-assets.mjs",
    "art:pixel-portraits": "node scripts/art/export-portrait-runtime-assets.mjs",
    "art:pixel-props": "node scripts/art/export-prop-runtime-assets.mjs",
    "art:pixel-terrain": "node scripts/art/export-terrain-runtime-assets.mjs",
    "art:pixel-walkers": "node scripts/art/export-walker-runtime-assets.mjs",
    "art:submit-pending": "node scripts/art/submit-pending-meshy.mjs",
    "art:harvest": "node scripts/art/harvest-meshy-ledger.mjs",
    "build": "pnpm -r build",
    "desktop:dev": "pnpm --filter @the-oracle/desktop start",
    "desktop:package": "pnpm --filter @the-oracle/desktop package",
    "desktop:make": "pnpm --filter @the-oracle/desktop make",
    "smoke:all-critical": "pnpm smoke:precinct && pnpm smoke:consultation && pnpm smoke:logistics && pnpm smoke:campaign && pnpm smoke:worldmap && pnpm smoke:origins && pnpm smoke:replay-debug",
    "smoke:campaign": "pnpm --filter @the-oracle/testkit smoke:campaign",
    "smoke:consultation": "pnpm --filter @the-oracle/testkit smoke:consultation",
    "smoke:desktop": "pnpm --filter @the-oracle/testkit smoke:desktop",
    "smoke:logistics": "pnpm --filter @the-oracle/testkit smoke:logistics",
    "smoke:origins": "pnpm --filter @the-oracle/testkit smoke:origins",
    "smoke:precinct": "pnpm --filter @the-oracle/testkit smoke:precinct",
    "smoke:replay-debug": "pnpm --filter @the-oracle/testkit smoke:replay-debug",
    "smoke:worldmap": "pnpm --filter @the-oracle/testkit smoke:worldmap",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint . --ext .ts,.tsx",
    "art:library": "node scripts/art/build-library.mjs",
    "art:submit": "node scripts/art/submit-library.mjs",
    "art:rename": "node scripts/art/rename-generated-batch.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
